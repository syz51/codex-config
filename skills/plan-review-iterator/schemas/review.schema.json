{
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "markdown_response", "findings", "unresolved_questions"],
  "properties": {
    "summary": { "type": "string" },
    "markdown_response": { "type": "string" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "severity", "confidence", "title", "location", "evidence", "recommendation", "actionable"],
        "properties": {
          "id": { "type": "string" },
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low", "info"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "title": { "type": "string" },
          "location": { "type": "string" },
          "evidence": { "type": "string" },
          "recommendation": { "type": "string" },
          "actionable": { "type": "boolean" }
        }
      }
    },
    "unresolved_questions": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
